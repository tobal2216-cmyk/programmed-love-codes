<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Programmed Love - Corazón Real</title>
    <style>
        body {
            margin: 0;
            background-color: #000;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            overflow: hidden;
            perspective: 1000px;
        }
        .container {
            position: relative;
            transform-style: preserve-3d;
        }
        .ui_love_word {
            color: #ea80b0;
            font-size: 1.2rem;
            font-family: Arial, sans-serif;
            position: absolute;
            text-shadow: 0 0 10px #ffb3d9;
            white-space: nowrap;
            opacity: 0;
            animation: heart-anim 4s infinite linear;
        }
        @keyframes heart-anim {
            0% { opacity: 0; transform: translate3d(var(--x), var(--y), -100px) scale(0.8); }
            50% { opacity: 1; transform: translate3d(var(--x), var(--y), 0px) scale(1.1); }
            100% { opacity: 0; transform: translate3d(var(--x), var(--y), 100px) scale(0.8); }
        }
    </style>
</head>
<body>
    <div class="container" id="heart-container"></div>

    <script>
        const container = document.getElementById('heart-container');
        const total = 60;

        for (let i = 0; i < total; i++) {
            const angle = (i / total) * Math.PI * 2;
            
            const x = 16 * Math.pow(Math.sin(angle), 3);
            const y = -(13 * Math.cos(angle) - 5 * Math.cos(2 * angle) - 2 * Math.cos(3 * angle) - Math.cos(4 * angle));

            const layer = document.createElement('div');
            layer.className = 'ui_love_word';
            layer.innerText = 'I love you';
            const scale = 15; 
            layer.style.setProperty('--x', `${x * scale}px`);
            layer.style.setProperty('--y', `${y * scale}px`);
            layer.style.animationDelay = `${(i * 0.1)}s`;

            container.appendChild(layer);
        }
    </script>
</body>
</html>
